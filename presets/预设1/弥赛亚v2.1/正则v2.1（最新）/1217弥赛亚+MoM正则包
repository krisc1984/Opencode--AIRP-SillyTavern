  background: rgba(255, 255, 255, 0.5);\n            padding: 10px 15px;\n            border-radius: 12px;\n            white-space: pre-wrap;\n        }\n\n        .status-bar-wrapper .pagination-controls {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            margin-top: 20px;\n            gap: 10px;\n        }\n        .status-bar-wrapper .page-indicator {\n            padding: 5px 12px;\n            border-radius: 15px;\n            background: #fceef1;\n            color: #d58a99;\n            font-size: 0.8em;\n            font-weight: bold;\n        }\n        .status-bar-wrapper .nav-button {\n            background: #ffffff;\n            border: 1px solid #fce0e5;\n            color: #e6aab6;\n            width: 30px;\n            height: 30px;\n            border-radius: 50%;\n            cursor: pointer;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            font-size: 1.2em;\n            transition: all 0.2s ease;\n        }\n        .status-bar-wrapper .nav-button:hover {\n            background: #fdf6f7;\n            color: #d58a99;\n        }\n        .status-bar-wrapper .nav-button:active {\n            transform: scale(0.9);\n            background: #fce0e5;\n        }\n\n        .status-bar-wrapper .hidden-data {\n            display: none;\n        }\n    </style>\n\n    <div class=\"status-bar-wrapper\">\n        <details>\n            <summary>\n                <span class=\"summary-title\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z\"></path><path d=\"m9 12 2 2 4-4\"></path></svg>\n                    <span>当前状态</span>\n                </span>\n                <!-- 新增的秘密信息 -->\n                <span class=\"secret-message\"> 哥哥在看着你哦(ˊ˘ˋ*)♡</span>\n                <span class=\"summary-icon\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"6 9 12 15 18 9\"></polyline></svg>\n                </span>\n            </summary>\n            <div class=\"status-content\">\n                <div class=\"pages-container\">\n\n                    <div class=\"page active\" id=\"page1\">\n                        <div class=\"info-block\"><div class=\"info-block-title\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M8 2v4\"></path><path d=\"M16 2v4\"></path><rect width=\"18\" height=\"18\" x=\"3\" y=\"4\" rx=\"2\"></rect><path d=\"M3 10h18\"></path></svg><span>时间</span></div><div class=\"info-block-content\">$1</div></div>\n                        <div class=\"info-block\"><div class=\"info-block-title\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z\"></path><circle cx=\"12\" cy=\"10\" r=\"3\"></circle></svg><span>位置</span></div><div class=\"info-block-content\">$2</div></div>\n                        <div class=\"info-block\"><div class=\"info-block-title\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"4\"></circle><path d=\"M12 2v2\"></path><path d=\"M12 20v2\"></path><path d=\"m4.93 4.93 1.41 1.41\"></path><path d=\"m17.66 17.66 1.41 1.41\"></path><path d=\"M2 12h2\"></path><path d=\"M20 12h2\"></path><path d=\"m4.93 19.07 1.41-1.41\"></path><path d=\"m17.66 6.34 1.41-1.41\"></path></svg><span>天气</span></div><div class=\"info-block-content\">$3</div></div>\n                        <div class=\"info-block\"><div class=\"info-block-title\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M17.7 17.7a2.1 2.1 0 1 0 0-3 2.1 2.1 0 0 0 0 3Z\"></path><path d=\"M6.3 6.3a2.1 2.1 0 1 0 0 3 2.1 2.1 0 0 0 0-3Z\"></path><path d=\"M12 12a2.1 2.1 0 1 0 0 3 2.1 2.1 0 0 0 0-3Z\"></path><path d=\"M3 3v18h18\"></path></svg><span>环境</span></div><div class=\"info-block-content\">$4</div></div>\n                    </div>\n\n                    <div class=\"page\" id=\"page2\">\n                        <div id=\"cha-container\"></div>\n                        <div class=\"hidden-data\" id=\"cha-raw-data\">$5</div>\n                    </div>\n\n                    <div class=\"page\" id=\"page3\">\n                        <div class=\"info-block\"><div class=\"info-block-title\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"8\" r=\"5\"></circle><path d=\"M20 21a8 8 0 0 0-16 0\"></path></svg><span>$6</span></div><div class=\"info-block-content\">$7</div></div>\n                    </div>\n                </div>\n                <div class=\"pagination-controls\">\n                    <button class=\"nav-button\" onclick=\"changePage(-1, this)\">‹</button>\n                    <span class=\"page-indicator\">1 / 3</span>\n                    <button class=\"nav-button\" onclick=\"changePage(1, this)\">›</button>\n                </div>\n            </div>\n        </details>\n    </div>\n\n    <script>\n        (function() {\n            function processAndInjectChaData() {\n                const rawDataElement = document.getElementById('cha-raw-data');\n                const container = document.getElementById('cha-container');\n                if (!rawDataElement || !container) return;\n                const rawHTML = rawDataElement.innerHTML;\n                container.innerHTML = '';\n                if (!rawHTML.trim()) {\n                    container.innerHTML = `<div class=\"info-block\" style=\"margin-top: 15px;\"><div class=\"info-block-content\" style=\"text-align: center; color: #b29a9a;\">当前没有同行的人，宝宝好像有点孤单呢……</div></div>`;\n                    return;\n                }\n                const chaItems = rawHTML.split(/&lt;cha&gt;|&lt;\\/cha&gt;/).filter(item => item.trim() !== '');\n                chaItems.forEach(item => {\n                    const parts = item.split(/:(.+)/);\n                    if (parts.length >= 2) {\n                        const name = parts[0].trim();\n                        const description = parts[1].trim();\n                        const npcBlock = document.createElement('div');\n                        npcBlock.innerHTML = `<div class=\"npc-block-title\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2\"></path><circle cx=\"9\" cy=\"7\" r=\"4\"></circle></svg><span>${name}</span></div><div class=\"info-block-content\">${description}</div>`;\n                        container.appendChild(npcBlock);\n                    }\n                });\n            }\n            function initializeStatusBar() {\n                setTimeout(processAndInjectChaData, 50);\n            }\n            initializeStatusBar();\n            if (typeof window.changePage !== 'function') {\n                window.changePage = function(direction, buttonElement) {\n                    const wrapper = buttonElement.closest('.status-bar-wrapper');\n                    if (!wrapper) return;\n                    const pages = wrapper.querySelectorAll('.page');\n                    const indicator = wrapper.querySelector('.page-indicator');\n                    let currentPageIndex = -1;\n                    pages.forEach((page, index) => { if (page.classList.contains('active')) { currentPageIndex = index; } });\n                    if (currentPageIndex === -1) return;\n                    pages[currentPageIndex].classList.remove('active');\n                    let nextPageIndex = (currentPageIndex + direction + pages.length) % pages.length;\n                    pages[nextPageIndex].classList.add('active');\n                    indicator.textContent = (nextPageIndex + 1) + ' / ' + pages.length;\n                }\n            }\n        })();\n    </script>\n</body>\n</html>\n```",
